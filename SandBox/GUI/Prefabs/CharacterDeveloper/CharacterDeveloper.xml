                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" HorizontalAlignment="Right" Sprite="CharacterDeveloper\little_progressbar_glow" Brush.AlphaFactor="0.5" />
                              </Children>
                            </Widget>

                          </Children>
                        </Widget>

                        <!--Skill Progress Text-->
