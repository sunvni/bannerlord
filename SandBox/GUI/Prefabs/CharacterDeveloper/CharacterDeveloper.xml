                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="4" VerticalAlignment="Center" MarginLeft="10" Sprite="Encyclopedia\list_filters_divider" />
                              </Children>
                            </ListPanel>

                            <ListPanel Id="SkillDescriptionAndEffects" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginBottom="5" IsVisible="false" LayoutImp.LayoutMethod="VerticalBottomToTop">
                              <Children>
                                <!--Skill Effect List-->
                                <ListPanel DataSource="{CurrentSkill\SkillEffects}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" LayoutImp.LayoutMethod="VerticalBottomToTop">
