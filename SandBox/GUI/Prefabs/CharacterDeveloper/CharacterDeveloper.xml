              </Children>
            </Widget>

          </Children>
        </ListPanel>

        <!--Left Panel-->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren" SuggestedWidth="!SidePanel.Width.Scaled" HorizontalAlignment="Left" VerticalAlignment="Center" MarginTop="!SidePanel.MarginTop" MarginBottom="!SidePanel.MarginBottom" Brush="Frame1.Broken.Left">
          <Children>

