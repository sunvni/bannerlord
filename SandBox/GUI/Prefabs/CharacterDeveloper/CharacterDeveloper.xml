                                <RichTextWidget DataSource="{CurrentSkill}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right" Brush="CharacterDeveloper.Skill.Stats.Text" Text="@DescriptionText" />

